{
  "version": 8,
  "name": "Candidate — ESA WorldCover overlay + OFM vector labels/water/roads + hillshade",
  "metadata": {
    "approach": "Path 4: real land-cover raster from ESA WorldCover 2021 (10m, downsampled to z=6 mosaic) bundled offline + thin vector overlay for water/places/roads + terrarium hillshade for depth"
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "worldcover": {
      "type": "image",
      "url": "__WORLDCOVER_URL__",
      "coordinates": [
        [-180.0, 73.125],
        [-126.5625, 73.125],
        [-126.5625, 50.625],
        [-180.0, 50.625]
      ]
    },
    "omt": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet",
      "attribution": "© OpenFreeMap, © OpenStreetMap"
    },
    "terrain": {
      "type": "raster-dem",
      "tiles": ["https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"],
      "encoding": "terrarium",
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 12,
      "attribution": "© AWS Open Data"
    }
  },
  "layers": [
    { "id": "background",
      "type": "background",
      "paint": { "background-color": "#ecdfb8" } },

    { "id": "worldcover-raster",
      "type": "raster",
      "source": "worldcover",
      "paint": {
        "raster-opacity": 0.92,
        "raster-saturation": 0.1
      } },

    { "id": "water",
      "type": "fill",
      "source": "omt", "source-layer": "water",
      "paint": { "fill-color": "#7aa9c2", "fill-outline-color": "#5c8b9f" } },

    { "id": "waterway-river",
      "type": "line",
      "source": "omt", "source-layer": "waterway",
      "minzoom": 4,
      "filter": ["any", ["==", ["get", "class"], "river"], ["==", ["get", "class"], "canal"]],
      "paint": {
        "line-color": "#4a7993",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.7, 10, 2.0, 14, 3.4]
      } },

    { "id": "waterway-stream",
      "type": "line",
      "source": "omt", "source-layer": "waterway",
      "minzoom": 7,
      "filter": ["any", ["==", ["get", "class"], "stream"], ["==", ["get", "class"], "drain"]],
      "paint": {
        "line-color": "#7aa9c2",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.3, 12, 0.9, 16, 1.6]
      } },

    { "id": "hillshade",
      "type": "hillshade",
      "source": "terrain",
      "paint": {
        "hillshade-exaggeration": 0.45,
        "hillshade-shadow-color": "rgba(60, 40, 20, 0.28)",
        "hillshade-highlight-color": "rgba(255, 250, 230, 0.18)",
        "hillshade-accent-color": "rgba(140, 100, 55, 0.14)",
        "hillshade-illumination-direction": 315
      } },

    { "id": "road-trunk-casing",
      "type": "line",
      "source": "omt", "source-layer": "transportation",
      "filter": ["any", ["==", ["get", "class"], "trunk"], ["==", ["get", "class"], "motorway"]],
      "minzoom": 4,
      "paint": {
        "line-color": "#f0e8d2",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 1.4, 8, 3, 12, 5, 16, 9]
      } },

    { "id": "road-trunk",
      "type": "line",
      "source": "omt", "source-layer": "transportation",
      "filter": ["any", ["==", ["get", "class"], "trunk"], ["==", ["get", "class"], "motorway"]],
      "minzoom": 4,
      "paint": {
        "line-color": "#5e3aa8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.6, 8, 1.8, 12, 3.5, 16, 6.5]
      } },

    { "id": "road-primary",
      "type": "line",
      "source": "omt", "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "primary"],
      "minzoom": 6,
      "paint": {
        "line-color": "#7b58c4",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.7, 10, 2.2, 16, 5]
      } },

    { "id": "road-secondary",
      "type": "line",
      "source": "omt", "source-layer": "transportation",
      "filter": ["any", ["==", ["get", "class"], "secondary"], ["==", ["get", "class"], "tertiary"]],
      "minzoom": 8,
      "paint": {
        "line-color": "#c89a5c",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.6, 12, 1.8, 16, 3.5]
      } },

    { "id": "boundary-country",
      "type": "line",
      "source": "omt", "source-layer": "boundary",
      "filter": ["all", ["==", ["get", "admin_level"], 2], ["!=", ["get", "maritime"], 1]],
      "minzoom": 1,
      "paint": {
        "line-color": "#523a18",
        "line-width": ["interpolate", ["linear"], ["zoom"], 1, 0.6, 6, 1.6],
        "line-dasharray": [4, 2],
        "line-opacity": 0.8
      } },

    { "id": "water-name",
      "type": "symbol",
      "source": "omt", "source-layer": "water_name",
      "minzoom": 5,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 11, 12, 16],
        "text-letter-spacing": 0.08,
        "symbol-placement": "line",
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "#15384e",
        "text-halo-color": "#f0e8d2",
        "text-halo-width": 1.5
      } },

    { "id": "mountain-peak",
      "type": "symbol",
      "source": "omt", "source-layer": "mountain_peak",
      "minzoom": 9,
      "layout": {
        "text-field": ["concat", ["coalesce", ["get", "name:en"], ["get", "name"]], "\n", ["get", "ele"], " m"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 10, 14, 13],
        "text-anchor": "top",
        "text-offset": [0, 0.6]
      },
      "paint": {
        "text-color": "#3a230d",
        "text-halo-color": "#f0e8d2",
        "text-halo-width": 1.7
      } },

    { "id": "place-village",
      "type": "symbol",
      "source": "omt", "source-layer": "place",
      "filter": ["any", ["==", ["get", "class"], "village"], ["==", ["get", "class"], "hamlet"]],
      "minzoom": 9,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 10, 14, 13]
      },
      "paint": {
        "text-color": "#3a2b18",
        "text-halo-color": "#f0e8d2",
        "text-halo-width": 1.6
      } },

    { "id": "place-town",
      "type": "symbol",
      "source": "omt", "source-layer": "place",
      "filter": ["==", ["get", "class"], "town"],
      "minzoom": 6,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 12, 13, 16]
      },
      "paint": {
        "text-color": "#1f1810",
        "text-halo-color": "#f0e8d2",
        "text-halo-width": 1.9
      } },

    { "id": "place-city",
      "type": "symbol",
      "source": "omt", "source-layer": "place",
      "filter": ["==", ["get", "class"], "city"],
      "minzoom": 4,
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 12, 10, 20],
        "text-letter-spacing": 0.04
      },
      "paint": {
        "text-color": "#15110a",
        "text-halo-color": "#f0e8d2",
        "text-halo-width": 2.4
      } },

    { "id": "place-region-letterpress",
      "type": "symbol",
      "source": "omt", "source-layer": "place",
      "filter": ["any", ["==", ["get", "class"], "state"], ["==", ["get", "class"], "province"]],
      "minzoom": 3, "maxzoom": 9,
      "layout": {
        "text-field": ["upcase", ["coalesce", ["get", "name:en"], ["get", "name"]]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 14, 6, 26, 9, 36],
        "text-letter-spacing": 0.45,
        "text-max-width": 9
      },
      "paint": {
        "text-color": "#5c4520",
        "text-halo-color": "#f0e8d2",
        "text-halo-width": 2.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.5, 6, 0.42, 9, 0.3]
      } }
  ]
}
