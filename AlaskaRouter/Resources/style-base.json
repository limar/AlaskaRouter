{
  "version": 8,
  "name": "AlaskaRouter base style (OpenTopoMap raster + offline glyphs)",
  "metadata": {
    "attribution": "Map data: © OpenStreetMap contributors. Tiles: © OpenTopoMap (CC-BY-SA)."
  },
  "glyphs": "__GLYPHS_URL_BASE__/{fontstack}/{range}.pbf",
  "sources": {
    "basemap": {
      "type": "raster",
      "url": "__BASEMAP_URL__",
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 10,
      "attribution": "© OpenTopoMap (CC-BY-SA), © OpenStreetMap"
    },
    "anchor-labels": {
      "type": "geojson",
      "data": "__ANCHOR_LABELS_URL__"
    },
    "places": {
      "type": "geojson",
      "data": "__PLACES_URL__"
    }
  },
  "layers": [
    { "id": "bg", "type": "background", "paint": { "background-color": "#f0e8d2" } },
    { "id": "basemap", "type": "raster", "source": "basemap" },

    {
      "id": "label-region",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "region"],
      "minzoom": 0,
      "maxzoom": 6,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 1, 14, 4, 26, 5, 32],
        "text-letter-spacing": 0.4,
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "text-padding": 8
      },
      "paint": {
        "text-color": "#3a3024",
        "text-halo-color": "rgba(255,250,238,0.85)",
        "text-halo-width": 1.6,
        "text-halo-blur": 0.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.0, 1, 0.5, 2.5, 0.95, 5, 0.85, 6, 0.0]
      }
    },

    {
      "id": "label-water",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "water"],
      "minzoom": 1,
      "maxzoom": 6,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 1, 10, 4, 14, 5, 16],
        "text-letter-spacing": 0.3,
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "text-padding": 6
      },
      "paint": {
        "text-color": "#34516e",
        "text-halo-color": "rgba(255,255,255,0.6)",
        "text-halo-width": 1.2,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 1, 0.0, 2, 0.7, 5, 0.7, 6, 0.0]
      }
    },

    {
      "id": "label-mountains",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "mountains"],
      "minzoom": 3,
      "maxzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 9, 5, 12, 7, 14],
        "text-letter-spacing": 0.1,
        "text-allow-overlap": false,
        "text-padding": 6
      },
      "paint": {
        "text-color": "#5a4a2e",
        "text-halo-color": "rgba(255,250,238,0.9)",
        "text-halo-width": 1.4,
        "text-halo-blur": 0.3,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.0, 4, 0.85, 7, 0.85, 8, 0.0]
      }
    },

    {
      "id": "label-city",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "city"],
      "minzoom": 3,
      "maxzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 10, 5, 13, 7, 15],
        "text-anchor": "top",
        "text-offset": [0, 0.6],
        "text-allow-overlap": false,
        "text-padding": 4
      },
      "paint": {
        "text-color": "#1a1a1a",
        "text-halo-color": "rgba(255,250,238,0.95)",
        "text-halo-width": 1.6,
        "text-halo-blur": 0.3,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.0, 4, 0.95, 7, 0.95, 8, 0.0]
      }
    },

    {
      "comment": "places-tier-* layers (vyfe). label-peak retired — major peaks surface via places-tier-natural-major at z>=7. Dots dropped after first user iteration: 'I see more dots than names'. MapLibre's text-allow-overlap=false already decimates labels at collision; without paired circles, the label IS the affordance and dot+name show/hide together. Areal features (lakes, glaciers, parks, islands) get label-only because they're visually identifiable on the basemap.",

      "id": "places-tier-major-settlement-label",
      "type": "symbol",
      "source": "places",
      "filter": ["==", ["get", "category"], "settlement_major"],
      "minzoom": 4,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 11, 8, 13, 12, 15],
        "text-letter-spacing": 0.05,
        "text-anchor": "center",
        "text-allow-overlap": false,
        "text-padding": 4
      },
      "paint": {
        "text-color": "#3a2a18",
        "text-halo-color": "rgba(255,250,238,0.95)",
        "text-halo-width": 1.5
      }
    },

    {
      "id": "places-tier-settlement-label",
      "type": "symbol",
      "source": "places",
      "filter": ["in", ["get", "category"], ["literal", ["settlement", "airfield", "visitor_center", "ranger_station"]]],
      "minzoom": 6,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 10, 10, 12, 14, 13],
        "text-anchor": "center",
        "text-allow-overlap": false,
        "text-padding": 3
      },
      "paint": {
        "text-color": ["match", ["get", "category"],
          "settlement",     "#3a2a18",
          "airfield",       "#384050",
          "visitor_center", "#705218",
          "ranger_station", "#1f4028",
          "#3a2a18"
        ],
        "text-halo-color": "rgba(255,250,238,0.92)",
        "text-halo-width": 1.4
      }
    },

    {
      "id": "places-tier-natural-major-label",
      "type": "symbol",
      "source": "places",
      "filter": ["all",
        ["in", ["get", "category"], ["literal", ["peak", "glacier", "park", "fuel"]]],
        [">=", ["get", "importance"], 0.6]
      ],
      "minzoom": 7,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 7, 9, 12, 11.5],
        "text-anchor": "center",
        "text-allow-overlap": false,
        "text-padding": 3
      },
      "paint": {
        "text-color": ["match", ["get", "category"],
          "peak",    "#5a2818",
          "glacier", "#2a5278",
          "park",    "#1f4028",
          "fuel",    "#883018",
          "#3a2a18"
        ],
        "text-halo-color": "rgba(255,250,238,0.92)",
        "text-halo-width": 1.4
      }
    },

    {
      "id": "places-tier-misc-label",
      "type": "symbol",
      "source": "places",
      "filter": ["in", ["get", "category"], ["literal", ["lake", "viewpoint", "attraction", "marina", "island", "volcano", "waterfall"]]],
      "minzoom": 9,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 9, 13, 11],
        "text-anchor": "center",
        "text-allow-overlap": false,
        "text-padding": 2
      },
      "paint": {
        "text-color": ["match", ["get", "category"],
          "lake",       "#1f4878",
          "viewpoint",  "#704018",
          "attraction", "#705218",
          "marina",     "#1f3850",
          "island",     "#3a2a18",
          "volcano",    "#883018",
          "waterfall",  "#1f4878",
          "#3a2a18"
        ],
        "text-halo-color": "rgba(255,250,238,0.9)",
        "text-halo-width": 1.3
      }
    },

    {
      "comment": "Long tail — every category not above. The categories we DO want (lake/island/volcano/waterfall) get richer styling above; everything else (food, store, hut, etc.) drops here at z>=11.",
      "id": "places-tier-long-tail-label",
      "type": "symbol",
      "source": "places",
      "filter": ["!", ["in", ["get", "category"], ["literal", [
        "settlement_major",
        "settlement", "airfield", "visitor_center", "ranger_station",
        "peak", "glacier", "park", "fuel",
        "lake", "viewpoint", "attraction", "marina", "island", "volcano", "waterfall"
      ]]]],
      "minzoom": 11,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 8.5, 16, 10.5],
        "text-anchor": "center",
        "text-allow-overlap": false,
        "text-padding": 2
      },
      "paint": {
        "text-color": "#3a2a18",
        "text-halo-color": "rgba(255,250,238,0.88)",
        "text-halo-width": 1.2
      }
    }
  ]
}
