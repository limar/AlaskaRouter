{
  "version": 8,
  "name": "AlaskaRouter base style (OpenTopoMap raster + offline glyphs)",
  "metadata": {
    "attribution": "Map data: © OpenStreetMap contributors. Tiles: © OpenTopoMap (CC-BY-SA)."
  },
  "glyphs": "__GLYPHS_URL_BASE__/{fontstack}/{range}.pbf",
  "sources": {
    "basemap": {
      "type": "raster",
      "url": "__BASEMAP_URL__",
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 10,
      "attribution": "© OpenTopoMap (CC-BY-SA), © OpenStreetMap"
    },
    "anchor-labels": {
      "type": "geojson",
      "data": "__ANCHOR_LABELS_URL__"
    },
    "places": {
      "type": "geojson",
      "data": "__PLACES_URL__"
    }
  },
  "layers": [
    { "id": "bg", "type": "background", "paint": { "background-color": "#f0e8d2" } },
    { "id": "basemap", "type": "raster", "source": "basemap" },

    {
      "id": "label-region",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "region"],
      "minzoom": 0,
      "maxzoom": 6,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 1, 14, 4, 26, 5, 32],
        "text-letter-spacing": 0.4,
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "text-padding": 8
      },
      "paint": {
        "text-color": "#3a3024",
        "text-halo-color": "rgba(255,250,238,0.85)",
        "text-halo-width": 1.6,
        "text-halo-blur": 0.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.0, 1, 0.5, 2.5, 0.95, 5, 0.85, 6, 0.0]
      }
    },

    {
      "id": "label-water",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "water"],
      "minzoom": 1,
      "maxzoom": 6,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 1, 10, 4, 14, 5, 16],
        "text-letter-spacing": 0.3,
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "text-padding": 6
      },
      "paint": {
        "text-color": "#34516e",
        "text-halo-color": "rgba(255,255,255,0.6)",
        "text-halo-width": 1.2,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 1, 0.0, 2, 0.7, 5, 0.7, 6, 0.0]
      }
    },

    {
      "id": "label-mountains",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "mountains"],
      "minzoom": 3,
      "maxzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 9, 5, 12, 7, 14],
        "text-letter-spacing": 0.1,
        "text-allow-overlap": false,
        "text-padding": 6
      },
      "paint": {
        "text-color": "#5a4a2e",
        "text-halo-color": "rgba(255,250,238,0.9)",
        "text-halo-width": 1.4,
        "text-halo-blur": 0.3,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.0, 4, 0.85, 7, 0.85, 8, 0.0]
      }
    },

    {
      "id": "label-city",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "city"],
      "minzoom": 3,
      "maxzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 10, 5, 13, 7, 15],
        "text-anchor": "top",
        "text-offset": [0, 0.6],
        "text-allow-overlap": false,
        "text-padding": 4
      },
      "paint": {
        "text-color": "#1a1a1a",
        "text-halo-color": "rgba(255,250,238,0.95)",
        "text-halo-width": 1.6,
        "text-halo-blur": 0.3,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.0, 4, 0.95, 7, 0.95, 8, 0.0]
      }
    },

    {
      "comment": "places-tier-* layers (vyfe iteration 3 — icons restored). Each symbol layer has both icon-image AND text-field; MapLibre's defaults (icon-optional=false, text-optional=false) mean BOTH must place or the whole symbol is dropped → icon and label show/hide together, fixing the 'more dots than names' problem. Areal categories (glacier, park, lake, island, waterfall) get icon-image=\"\" so they have NO marker — they're identifiable as shapes on the basemap, and the label is centered on the centroid.",

      "id": "places-tier-major-settlement",
      "type": "symbol",
      "source": "places",
      "filter": ["==", ["get", "category"], "settlement_major"],
      "minzoom": 4,
      "layout": {
        "icon-image": "place-settlement_major",
        "icon-size": ["interpolate", ["linear"], ["zoom"], 4, 0.8, 10, 1.0],
        "icon-anchor": "center",
        "icon-allow-overlap": false,
        "icon-padding": 1,
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 11, 8, 13, 12, 15],
        "text-letter-spacing": 0.05,
        "text-anchor": "top",
        "text-offset": [0, 0.55],
        "text-allow-overlap": false,
        "text-padding": 4
      },
      "paint": {
        "text-color": "#3a2a18",
        "text-halo-color": "rgba(255,250,238,0.95)",
        "text-halo-width": 1.5
      }
    },

    {
      "id": "places-tier-settlement",
      "type": "symbol",
      "source": "places",
      "filter": ["in", ["get", "category"], ["literal", ["settlement", "airfield", "visitor_center", "ranger_station"]]],
      "minzoom": 6,
      "layout": {
        "icon-image": ["match", ["get", "category"],
          "settlement",     "place-settlement",
          "airfield",       "place-airfield",
          "visitor_center", "place-visitor_center",
          "ranger_station", "place-ranger_station",
          ""
        ],
        "icon-size": ["interpolate", ["linear"], ["zoom"], 6, 0.75, 12, 1.0],
        "icon-anchor": "center",
        "icon-allow-overlap": false,
        "icon-padding": 1,
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 10, 10, 12, 14, 13],
        "text-anchor": "top",
        "text-offset": [0, 0.55],
        "text-allow-overlap": false,
        "text-padding": 3
      },
      "paint": {
        "text-color": ["match", ["get", "category"],
          "settlement",     "#3a2a18",
          "airfield",       "#384050",
          "visitor_center", "#705218",
          "ranger_station", "#1f4028",
          "#3a2a18"
        ],
        "text-halo-color": "rgba(255,250,238,0.92)",
        "text-halo-width": 1.4
      }
    },

    {
      "id": "places-tier-natural-major",
      "type": "symbol",
      "source": "places",
      "filter": ["all",
        ["in", ["get", "category"], ["literal", ["peak", "glacier", "park", "fuel"]]],
        [">=", ["get", "importance"], 0.6]
      ],
      "minzoom": 7,
      "layout": {
        "icon-image": ["match", ["get", "category"],
          "peak", "place-peak",
          "fuel", "place-fuel",
          ""
        ],
        "icon-size": ["interpolate", ["linear"], ["zoom"], 7, 0.7, 13, 1.0],
        "icon-anchor": "center",
        "icon-allow-overlap": false,
        "icon-padding": 1,
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 7, 9, 12, 11.5],
        "text-anchor": ["match", ["get", "category"],
          "glacier", "center",
          "park",    "center",
          "top"
        ],
        "text-offset": ["match", ["get", "category"],
          "glacier", ["literal", [0, 0]],
          "park",    ["literal", [0, 0]],
          ["literal", [0, 0.55]]
        ],
        "text-allow-overlap": false,
        "text-padding": 3
      },
      "paint": {
        "text-color": ["match", ["get", "category"],
          "peak",    "#5a2818",
          "glacier", "#2a5278",
          "park",    "#1f4028",
          "fuel",    "#883018",
          "#3a2a18"
        ],
        "text-halo-color": "rgba(255,250,238,0.92)",
        "text-halo-width": 1.4
      }
    },

    {
      "id": "places-tier-misc",
      "type": "symbol",
      "source": "places",
      "filter": ["in", ["get", "category"], ["literal", ["lake", "viewpoint", "attraction", "marina", "island", "volcano", "waterfall"]]],
      "minzoom": 9,
      "layout": {
        "icon-image": ["match", ["get", "category"],
          "viewpoint",  "place-viewpoint",
          "attraction", "place-attraction",
          "marina",     "place-marina",
          "volcano",    "place-volcano",
          ""
        ],
        "icon-size": ["interpolate", ["linear"], ["zoom"], 9, 0.7, 14, 1.0],
        "icon-anchor": "center",
        "icon-allow-overlap": false,
        "icon-padding": 1,
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 9, 13, 11],
        "text-anchor": ["match", ["get", "category"],
          "lake",      "center",
          "island",    "center",
          "waterfall", "center",
          "top"
        ],
        "text-offset": ["match", ["get", "category"],
          "lake",      ["literal", [0, 0]],
          "island",    ["literal", [0, 0]],
          "waterfall", ["literal", [0, 0]],
          ["literal", [0, 0.55]]
        ],
        "text-allow-overlap": false,
        "text-padding": 2
      },
      "paint": {
        "text-color": ["match", ["get", "category"],
          "lake",       "#1f4878",
          "viewpoint",  "#704018",
          "attraction", "#705218",
          "marina",     "#1f3850",
          "island",     "#3a2a18",
          "volcano",    "#883018",
          "waterfall",  "#1f4878",
          "#3a2a18"
        ],
        "text-halo-color": "rgba(255,250,238,0.9)",
        "text-halo-width": 1.3
      }
    },

    {
      "comment": "Long tail — every category not above. Gets the generic dot.",
      "id": "places-tier-long-tail",
      "type": "symbol",
      "source": "places",
      "filter": ["!", ["in", ["get", "category"], ["literal", [
        "settlement_major",
        "settlement", "airfield", "visitor_center", "ranger_station",
        "peak", "glacier", "park", "fuel",
        "lake", "viewpoint", "attraction", "marina", "island", "volcano", "waterfall"
      ]]]],
      "minzoom": 11,
      "layout": {
        "icon-image": ["concat", "place-", ["get", "category"]],
        "icon-size": ["interpolate", ["linear"], ["zoom"], 11, 0.65, 16, 0.95],
        "icon-anchor": "center",
        "icon-allow-overlap": false,
        "icon-padding": 1,
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 8.5, 16, 10.5],
        "text-anchor": "top",
        "text-offset": [0, 0.5],
        "text-allow-overlap": false,
        "text-padding": 2
      },
      "paint": {
        "text-color": "#3a2a18",
        "text-halo-color": "rgba(255,250,238,0.88)",
        "text-halo-width": 1.2
      }
    }
  ]
}
