{
  "version": 8,
  "name": "AlaskaRouter base style (OpenTopoMap raster + offline glyphs)",
  "metadata": {
    "attribution": "Map data: © OpenStreetMap contributors. Tiles: © OpenTopoMap (CC-BY-SA)."
  },
  "glyphs": "__GLYPHS_URL_BASE__/{fontstack}/{range}.pbf",
  "sources": {
    "basemap": {
      "type": "raster",
      "url": "__BASEMAP_URL__",
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 10,
      "attribution": "© OpenTopoMap (CC-BY-SA), © OpenStreetMap"
    },
    "anchor-labels": {
      "type": "geojson",
      "data": "__ANCHOR_LABELS_URL__"
    },
    "places": {
      "type": "geojson",
      "data": "__PLACES_URL__"
    }
  },
  "layers": [
    { "id": "bg", "type": "background", "paint": { "background-color": "#f0e8d2" } },
    { "id": "basemap", "type": "raster", "source": "basemap" },

    {
      "id": "label-region",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "region"],
      "minzoom": 0,
      "maxzoom": 6,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 1, 14, 4, 26, 5, 32],
        "text-letter-spacing": 0.4,
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "text-padding": 8
      },
      "paint": {
        "text-color": "#3a3024",
        "text-halo-color": "rgba(255,250,238,0.85)",
        "text-halo-width": 1.6,
        "text-halo-blur": 0.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 0, 0.0, 1, 0.5, 2.5, 0.95, 5, 0.85, 6, 0.0]
      }
    },

    {
      "id": "label-water",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "water"],
      "minzoom": 1,
      "maxzoom": 6,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 1, 10, 4, 14, 5, 16],
        "text-letter-spacing": 0.3,
        "text-allow-overlap": false,
        "text-ignore-placement": false,
        "text-padding": 6
      },
      "paint": {
        "text-color": "#34516e",
        "text-halo-color": "rgba(255,255,255,0.6)",
        "text-halo-width": 1.2,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 1, 0.0, 2, 0.7, 5, 0.7, 6, 0.0]
      }
    },

    {
      "id": "label-mountains",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "mountains"],
      "minzoom": 3,
      "maxzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 9, 5, 12, 7, 14],
        "text-letter-spacing": 0.1,
        "text-allow-overlap": false,
        "text-padding": 6
      },
      "paint": {
        "text-color": "#5a4a2e",
        "text-halo-color": "rgba(255,250,238,0.9)",
        "text-halo-width": 1.4,
        "text-halo-blur": 0.3,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.0, 4, 0.85, 7, 0.85, 8, 0.0]
      }
    },

    {
      "id": "label-city",
      "type": "symbol",
      "source": "anchor-labels",
      "filter": ["==", ["get", "tier"], "city"],
      "minzoom": 3,
      "maxzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 10, 5, 13, 7, 15],
        "text-anchor": "top",
        "text-offset": [0, 0.6],
        "text-allow-overlap": false,
        "text-padding": 4
      },
      "paint": {
        "text-color": "#1a1a1a",
        "text-halo-color": "rgba(255,250,238,0.95)",
        "text-halo-width": 1.6,
        "text-halo-blur": 0.3,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 3, 0.0, 4, 0.95, 7, 0.95, 8, 0.0]
      }
    },

    {
      "comment": "label-peak retired in AlaskaRouter-vyfe — peaks are now part of the places layer at z>=10.",
      "id": "places-tier-major-settlement",
      "type": "circle",
      "source": "places",
      "filter": ["==", ["get", "category"], "settlement_major"],
      "minzoom": 6,
      "paint": {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 6, 2, 10, 3, 14, 4],
        "circle-color": "#7a4a2a",
        "circle-stroke-width": 0.6,
        "circle-stroke-color": "rgba(255,250,238,0.9)"
      }
    },
    {
      "id": "places-tier-major-settlement-label",
      "type": "symbol",
      "source": "places",
      "filter": ["==", ["get", "category"], "settlement_major"],
      "minzoom": 6,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 11, 10, 13, 14, 15],
        "text-anchor": "top",
        "text-offset": [0, 0.6],
        "text-allow-overlap": false,
        "text-padding": 4
      },
      "paint": {
        "text-color": "#1a1a1a",
        "text-halo-color": "rgba(255,250,238,0.95)",
        "text-halo-width": 1.4
      }
    },

    {
      "id": "places-tier-settlement",
      "type": "circle",
      "source": "places",
      "filter": ["in", ["get", "category"], ["literal", ["settlement", "airfield", "visitor_center", "ranger_station"]]],
      "minzoom": 8,
      "paint": {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 8, 2, 14, 3.5],
        "circle-color": ["match", ["get", "category"],
          "settlement",       "#a87050",
          "airfield",         "#4a5060",
          "visitor_center",   "#b58932",
          "ranger_station",   "#2d5a3a",
          "#7a4a2a"
        ],
        "circle-stroke-width": 0.5,
        "circle-stroke-color": "rgba(255,250,238,0.9)"
      }
    },
    {
      "id": "places-tier-settlement-label",
      "type": "symbol",
      "source": "places",
      "filter": ["in", ["get", "category"], ["literal", ["settlement", "airfield", "visitor_center", "ranger_station"]]],
      "minzoom": 9,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 10, 14, 12],
        "text-anchor": "top",
        "text-offset": [0, 0.6],
        "text-allow-overlap": false,
        "text-padding": 3
      },
      "paint": {
        "text-color": "#2a2a2a",
        "text-halo-color": "rgba(255,250,238,0.9)",
        "text-halo-width": 1.3
      }
    },

    {
      "id": "places-tier-natural-major",
      "type": "circle",
      "source": "places",
      "filter": ["all",
        ["in", ["get", "category"], ["literal", ["peak", "glacier", "park", "fuel"]]],
        [">=", ["get", "importance"], 0.6]
      ],
      "minzoom": 10,
      "paint": {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 10, 2, 14, 3],
        "circle-color": ["match", ["get", "category"],
          "peak",    "#8b3a1f",
          "glacier", "#7fb5d4",
          "park",    "#3d6e3a",
          "fuel",    "#c85020",
          "#7a4a2a"
        ],
        "circle-stroke-width": 0.5,
        "circle-stroke-color": "rgba(255,250,238,0.85)"
      }
    },
    {
      "id": "places-tier-natural-major-label",
      "type": "symbol",
      "source": "places",
      "filter": ["all",
        ["in", ["get", "category"], ["literal", ["peak", "glacier", "park", "fuel"]]],
        [">=", ["get", "importance"], 0.6]
      ],
      "minzoom": 10,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 9, 14, 11],
        "text-anchor": "bottom",
        "text-offset": [0, -0.6],
        "text-allow-overlap": false,
        "text-padding": 3
      },
      "paint": {
        "text-color": "#3a2a1a",
        "text-halo-color": "rgba(255,250,238,0.9)",
        "text-halo-width": 1.3
      }
    },

    {
      "id": "places-tier-misc",
      "type": "circle",
      "source": "places",
      "filter": ["in", ["get", "category"], ["literal", ["lake", "viewpoint", "attraction", "marina"]]],
      "minzoom": 12,
      "paint": {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 12, 1.8, 14, 2.8],
        "circle-color": ["match", ["get", "category"],
          "lake",       "#4a87b4",
          "viewpoint",  "#c87832",
          "attraction", "#b58932",
          "marina",     "#3a5a78",
          "#7a4a2a"
        ],
        "circle-stroke-width": 0.4,
        "circle-stroke-color": "rgba(255,250,238,0.85)"
      }
    },
    {
      "id": "places-tier-misc-label",
      "type": "symbol",
      "source": "places",
      "filter": ["in", ["get", "category"], ["literal", ["lake", "viewpoint", "attraction", "marina"]]],
      "minzoom": 13,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 9, 15, 11],
        "text-anchor": "bottom",
        "text-offset": [0, -0.6],
        "text-allow-overlap": false,
        "text-padding": 2
      },
      "paint": {
        "text-color": "#3a2a1a",
        "text-halo-color": "rgba(255,250,238,0.85)",
        "text-halo-width": 1.2
      }
    },

    {
      "comment": "Long tail — every other category not above. Caught by !in test on the unioned set used in higher tiers.",
      "id": "places-tier-long-tail",
      "type": "circle",
      "source": "places",
      "filter": ["!", ["in", ["get", "category"], ["literal", [
        "settlement_major",
        "settlement", "airfield", "visitor_center", "ranger_station",
        "peak", "glacier", "park", "fuel",
        "lake", "viewpoint", "attraction", "marina"
      ]]]],
      "minzoom": 14,
      "paint": {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 14, 1.8, 16, 2.5],
        "circle-color": "#6a4a2a",
        "circle-stroke-width": 0.3,
        "circle-stroke-color": "rgba(255,250,238,0.8)"
      }
    },
    {
      "id": "places-tier-long-tail-label",
      "type": "symbol",
      "source": "places",
      "filter": ["!", ["in", ["get", "category"], ["literal", [
        "settlement_major",
        "settlement", "airfield", "visitor_center", "ranger_station",
        "peak", "glacier", "park", "fuel",
        "lake", "viewpoint", "attraction", "marina"
      ]]]],
      "minzoom": 14,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 9, 16, 10.5],
        "text-anchor": "bottom",
        "text-offset": [0, -0.55],
        "text-allow-overlap": false,
        "text-padding": 2
      },
      "paint": {
        "text-color": "#3a2a1a",
        "text-halo-color": "rgba(255,250,238,0.85)",
        "text-halo-width": 1.2
      }
    }
  ]
}
