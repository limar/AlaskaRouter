# macOS
.DS_Store

# Xcode derived data — narrow paths so we don't shadow scripts directories
spikes/A_maplibre/build/
spikes/C_icons/build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/

# Generated by xcodegen — project.yml is the source of truth
spikes/A_maplibre/AlaskaRouterSpike.xcodeproj/
spikes/C_icons/IconsSpike.xcodeproj/
AlaskaRouter.xcodeproj/

# Xcode derived data at repo root (real app)
/build/

# SwiftPM
.build/
Package.resolved
.swiftpm/

# Pipeline scratch data — regenerable from build scripts, too large for git.
# The OSM PBF (~140 MB), filtered PBF, GeoJSON export, and GNIS .txt all live
# here; tools/build-places/run.sh writes pois.sqlite into it and the user
# manually copies the final DB to AlaskaRouter/Resources/alaska-places.sqlite.
tools/build-places/data/

# Tile packs — too large for GitHub's 100 MB/file cap (AlaskaRouter-76y3).
# Distributed via GitHub Releases. See tools/build-pack/fetch-pack.sh to
# pull the current release asset, or tools/build-pack/download_tiles.py to
# regenerate from OpenTopoMap from scratch.
*.pmtiles
# SHA-256 sidecars are release-time artifacts (created by release-pack.sh,
# consumed by fetch-pack.sh against the release asset). No need to commit.
*.pmtiles.sha256
*.manifest.json.sha256

# Claude Code per-user (not shared); settings.json is shared and committed
.claude/settings.local.json
.claude/worktrees/

# Editor noise
*.swp
.idea/
.vscode/
spikes/A_maplibre/Resources-secrets/

# Claude Code scheduled-task state
.claude/scheduled_tasks.lock
AlaskaRouter/Resources/*.sqlite-shm
AlaskaRouter/Resources/*.sqlite-wal
